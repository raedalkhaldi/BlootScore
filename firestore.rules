rules_version = '2';

// BlootScore Firestore rules
// المشروع مشترك مع FlickMatch — نستخدم collections باسم bloot_* فقط
// جميع القواعد الأخرى تبقى مرفوضة افتراضياً
service cloud.firestore {
  match /databases/{database}/documents {

    // إعدادات الأدمن (UID واحد فقط)
    match /bloot_config/admin {
      allow read: if request.auth != null;

      // أول مرة: أي مستخدم مسجّل يقدر ينشئ الوثيقة بـ UID حقه
      allow create: if request.auth != null
                    && request.resource.data.adminUID == request.auth.uid;

      // بعدها: فقط الأدمن الحالي يقدر يعدّل، ولا يقدر يغيّر الـ UID لغيره
      allow update: if request.auth != null
                    && resource.data.adminUID == request.auth.uid
                    && request.resource.data.adminUID == request.auth.uid;

      allow delete: if false;
    }

    // الأصوات — قراءة لكل مستخدم مسجّل، الكتابة للأدمن فقط
    match /bloot_voices/{state} {
      allow read: if request.auth != null;
      allow write: if request.auth != null
                   && request.auth.uid ==
                      get(/databases/$(database)/documents/bloot_config/admin).data.adminUID;
    }

    // افتراضياً — كل شي ثاني مرفوض (نفس السلوك السابق)
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
